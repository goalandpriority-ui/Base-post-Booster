generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Boost {
  id        String   @id @default(cuid())

  // user wallet address
  wallet    String

  // boosted post URL
  postUrl   String

  // token contract address (Base chain)
  contract  String

  // transaction hash (must be unique)
  txHash    String   @unique

  // boost payment amount
  amount    Float

  // referral wallet (optional)
  referrer  String?

  // timestamp
  createdAt DateTime @default(now())

  // indexes for faster queries
  @@index([postUrl])
  @@index([wallet])
  @@index([contract])
  @@index([createdAt])
  @@index([referrer])

  // useful for trending calculations
  @@index([postUrl, createdAt])
}
