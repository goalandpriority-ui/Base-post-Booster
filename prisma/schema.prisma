generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Boost {
  id        String   @id @default(cuid())
  wallet    String   // user wallet address
  postUrl   String   // boosted post URL
  contract  String   // ✅ token contract address (Base chain)
  txHash    String   // transaction hash
  amount    Float    // boost amount
  createdAt DateTime @default(now())

  @@index([postUrl])
  @@index([wallet])
  @@index([contract])
}
