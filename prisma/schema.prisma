generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Boost {
  id        String   @id @default(cuid())

  // user wallet address
  wallet    String

  // boosted post URL
  postUrl   String

  // token contract address (Base chain)
  contract  String?

  // transaction hash (must be unique)
  txHash    String   @unique

  // boost payment amount (better precision than Float)
  amount    Decimal  @db.Decimal(18,6)

  // referral wallet (optional)
  referrer  String?

  // timestamp
  createdAt DateTime @default(now())

  /* ---------- INDEXES ---------- */

  // quick lookup for post boosts
  @@index([postUrl])

  // wallet history
  @@index([wallet])

  // token boost lookup
  @@index([contract])

  // time based queries
  @@index([createdAt])

  // referral earnings queries
  @@index([referrer])

  // trending posts calculation
  @@index([postUrl, createdAt])

  // trending tokens calculation
  @@index([contract, createdAt])

  // leaderboard queries
  @@index([wallet, createdAt])

  // referral earnings calculation
  @@index([referrer, createdAt])
}
