generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Boost {
  id        String   @id @default(cuid())

  // user wallet address
  wallet    String

  // boosted post URL
  postUrl   String

  // token contract address (Base chain)
  contract  String?

  // transaction hash (must be unique)
  txHash    String   @unique

  // boost payment amount
  amount    Decimal  @db.Decimal(18,6)

  // trending score (pre-calculated)
  score     Float    @default(0)

  // boost plan (basic / pro / elite)
  plan      String   @default("basic")

  // boost duration
  durationHours Int  @default(24)

  // referral wallet
  referrer  String?

  // timestamp
  createdAt DateTime @default(now())

  // INDEXES

  @@index([postUrl])
  @@index([wallet])
  @@index([contract])
  @@index([createdAt])
  @@index([referrer])

  // trending queries
  @@index([contract, createdAt])
  @@index([postUrl, createdAt])
  @@index([score])
}
